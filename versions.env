# === Piper MoveIt Docker — 핀 버전 (재현성) ===
# 이미지 좌표
OWNER=Bigenlight               # GitHub 계정. 로컬 빌드는 OWNER 무관. GHCR pull 시에만 사용.
IMAGE_NAME=piper-moveit
IMAGE_TAG=jazzy
# 로컬: piper-moveit:jazzy   /   GHCR: ghcr.io/${OWNER}/${IMAGE_NAME}:${IMAGE_TAG}

# 베이스 (Tiryoh noVNC ROS2 Jazzy 데스크탑). digest 핀 = 재현성 보장(:jazzy 태그는 시간 지나면 갱신됨).
# 이 digest는 multi-arch 인덱스 매니페스트라 amd64/arm64 둘 다 동일하게 동작.
# 태그로 되돌리려면: BASE_IMAGE=ghcr.io/tiryoh/ros2-desktop-vnc:jazzy
BASE_IMAGE=ghcr.io/tiryoh/ros2-desktop-vnc:jazzy@sha256:0a5fc748ec422a3d293341e0ecbce27bd3d3d20a7b9dad01b28bdefe2ba76e0b

# AgileX 핀 (릴리스 태그 없음 → commit SHA 고정)
AGX_ARM_ROS_SHA=e649916179f19b29fdcfbe00b23a54afbc1c024d
PYAGXARM_SHA=a226840db0c3d5c5dc7f3ec78d6cef1a6800f9e6

# 런타임 기본값
ARM_TYPE=piper
EFFECTOR_TYPE=agx_gripper
CAN_IFACE=can0
CAN_BITRATE=1000000
NOVNC_PORT=6080
